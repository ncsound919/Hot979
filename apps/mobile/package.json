{
  "name": "hot979-mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:android": "expo build:android",
    "build:ios": "expo build:ios",
    "lint": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "test:e2e": "detox test",
    "test:e2e:emu": "detox test --configuration android.debug.emu",
    "test:e2e:dev": "detox test --configuration android.debug.dev",
    "e2e:build": "detox build --configuration android.debug.emu",
    "e2e:build:release": "detox build --configuration android.release.emu",
    "clean": "npx expo prebuild --clean",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native-community/slider": "^4.5.5",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-keep-awake": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "lucide-react-native": "^0.546.0",
    "react": "18.3.1",
    "react-native": "^0.76.9",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-track-player": "^4.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.0",
    "detox": "^20.51.4",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "react-native-svg": "^15.8.0",
    "react-test-renderer": "^18.3.1",
    "typescript": "~5.3.0"
  }
}
